<UserControl x:Class="EndoscopyApp.Views.RecordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:EndoscopyApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="Standard" Background="White" Padding="16" Grid.Row="0"
                                  Visibility="{Binding IsFullscreen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding NavigateBackCommand}" 
                            Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="0" Width="40" Height="40" Margin="0,0,16,0">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Foreground="Black"/>
                    </Button>
                    <StackPanel>
                        <TextBlock Text="Live Recording" FontSize="24" FontWeight="Bold" Foreground="Black"/>
                        <StackPanel Orientation="Horizontal" Visibility="{Binding IsPatientRegistered, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Patient: " Foreground="#718096" FontSize="14"/>
                            <TextBlock Text="{Binding PatientName}" Foreground="#2D3748" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text="  (" Foreground="#718096" FontSize="14"/>
                            <TextBlock Text="{Binding PatientId}" Foreground="#2D3748" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Text=")" Foreground="#718096" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Recording Status -->
                <materialDesign:Chip HorizontalAlignment="Right" Background="#E53E3E" Foreground="White" 
                                    Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Content="Recording" VerticalAlignment="Center">
                    <materialDesign:Chip.Icon>
                        <Ellipse Width="10" Height="10" Fill="White" Margin="4"/>
                    </materialDesign:Chip.Icon>
                </materialDesign:Chip>
            </Grid>
        </materialDesign:ColorZone>


        <!-- Bottom Bar -->
        <Border Grid.Row="2" Padding="20" Background="#0F172A"
                Visibility="{Binding IsFullscreen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
             <Grid>
                <!-- Initial State: Snapshot & Record -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                            Visibility="{Binding IsRecording, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Button Command="{Binding TakeSnapshotCommand}" 
                            Background="#4C51BF" Foreground="White" Width="220" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,20,0"
                            IsEnabled="{Binding IsCameraRunning}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CameraOutline" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Snapshot" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ToggleRecordingCommand}" 
                            Background="#E53E3E" Foreground="White" Width="220" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="10"
                            IsEnabled="{Binding IsCameraRunning}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="RecordCircleOutline" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Record" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Recording State: Stop & Save & Cancel -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                            Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Command="{Binding ToggleRecordingCommand}" 
                            Background="#38A169" Foreground="White" Width="220" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="10" Margin="0,0,20,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="RecordCircle" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Stop &amp; Save" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelRecordingCommand}" 
                            Background="#E53E3E" Foreground="White" Width="220" Height="50"
                            materialDesign:ButtonAssist.CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Video Area -->
        <Border Background="Black" Panel.ZIndex="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Grid.Row" Value="1"/>
                    <Setter Property="Grid.RowSpan" Value="1"/>
                    <Setter Property="Margin" Value="20"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                            <Setter Property="Grid.Row" Value="0"/>
                            <Setter Property="Grid.RowSpan" Value="3"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Image Source="{Binding CurrentFrame}" Stretch="Uniform"/>
                <Button Command="{Binding ToggleFullscreenCommand}"
                        Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Width="40" Height="40" Margin="16"
                        Background="#66000000" BorderBrush="Transparent">
                    <materialDesign:PackIcon Kind="{Binding IsFullscreen, Converter={StaticResource FullscreenIconConverter}}" 
                                            Width="24" Height="24" Foreground="White"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>

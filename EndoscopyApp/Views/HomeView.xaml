<UserControl x:Class="EndoscopyApp.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EndoscopyApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024"
             Background="#F5F7FA">
    <Grid Margin="50">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Globe" Width="32" Height="32" Foreground="#333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="BMI" FontSize="32" FontWeight="ExtraBold" Foreground="#1A202C" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding SettingsCommand}" 
                        Background="#FFF" Foreground="#4A5568" 
                        BorderBrush="#E2E8F0" Height="48" Padding="20,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Settings" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                        <TextBlock Text="Settings" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding LogoutCommand}" 
                        Background="#FED7D7" Foreground="#C53030" 
                        BorderBrush="Transparent" Height="48" Padding="20,0" Margin="20,0,0,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" VerticalAlignment="Center" Margin="0,0,10,0" Width="20" Height="20"/>
                        <TextBlock Text="Logout" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Dashboard Cards Section -->
        <Grid Grid.Row="1" VerticalAlignment="Center">
            <UniformGrid Columns="3" Margin="-15">
                <!-- Patient Details Card -->
                <Button Command="{Binding NavigateToPatientDetailsCommand}" 
                        Height="280" Margin="15"
                        Background="#4C51BF" Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="24">
                    <materialDesign:Card Background="Transparent">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#3EFFFFFF" CornerRadius="30" Width="80" Height="80" Margin="0,0,0,25">
                                    <materialDesign:PackIcon Kind="AccountGroup" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Patient Details" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Add and manage patient information" Foreground="#E2E8F0" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Button>

                <!-- Live Card -->
                <Button Command="{Binding NavigateToLiveCommand}" 
                        Height="280" Margin="15"
                        Background="#38A169" Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="24">
                    <materialDesign:Card Background="Transparent">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#3EFFFFFF" CornerRadius="30" Width="80" Height="80" Margin="0,0,0,25">
                                    <materialDesign:PackIcon Kind="Cctv" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Live" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Record live endoscopy" Foreground="#E2E8F0" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Button>

                <!-- Recorded Videos Card -->
                <Button Command="{Binding NavigateToRecordedVideosCommand}" 
                        Height="280" Margin="15"
                        Background="#d55a5aff" Padding="0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        materialDesign:ButtonAssist.CornerRadius="24">
                    <materialDesign:Card Background="Transparent">
                        <Grid>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Border Background="#3EFFFFFF" CornerRadius="30" Width="80" Height="80" Margin="0,0,0,25">
                                    <materialDesign:PackIcon Kind="FolderPlay" Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                                </Border>
                                <TextBlock Text="Record Video" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Start a new recording session" Foreground="#E2E8F0" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="200"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </Button>
            </UniformGrid>
        </Grid>
    </Grid>
</UserControl>

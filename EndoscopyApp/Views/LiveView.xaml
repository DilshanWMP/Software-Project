<UserControl x:Class="EndoscopyApp.Views.LiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:viewmodels="clr-namespace:EndoscopyApp.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="768" d:DesignWidth="1024">
    <Grid Background="Black">
        <!-- Back Button -->
        <Button Command="{Binding NavigateBackCommand}" 
                Style="{StaticResource MaterialDesignFlatButton}" 
                Padding="0" HorizontalAlignment="Left" VerticalAlignment="Top"
                Width="48" Height="48" Margin="16">
            <materialDesign:PackIcon Kind="ArrowLeft" Width="28" Height="28" Foreground="White"/>
        </Button>

        <!-- Live Badge -->
        <materialDesign:Chip HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Background="#E53E3E" Foreground="White" 
                            Content="Live" Margin="16">
            <materialDesign:Chip.Icon>
                <Ellipse Width="10" Height="10" Fill="White" Margin="4"/>
            </materialDesign:Chip.Icon>
        </materialDesign:Chip>

        <!-- Video Feed -->
        <Image Source="{Binding CurrentFrame}" Stretch="Uniform"/>

        <!-- Bottom Controls (Overlay) -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="20" Orientation="Horizontal">
             <Button Command="{Binding StartCameraCommand}" Content="Start Camera" Margin="0,0,10,0" 
                     Visibility="{Binding IsCameraRunning, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
             <Button Command="{Binding StopCameraCommand}" Content="Stop Camera" Style="{StaticResource MaterialDesignOutlinedButton}" 
                     Visibility="{Binding IsCameraRunning, Converter={StaticResource BooleanToVisibilityConverter}}" 
                     Foreground="White" BorderBrush="White"/>
        </StackPanel>
        
        <materialDesign:PackIcon Kind="Fullscreen" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                                Margin="16" Width="24" Height="24" Foreground="White"/>
    </Grid>
</UserControl>
